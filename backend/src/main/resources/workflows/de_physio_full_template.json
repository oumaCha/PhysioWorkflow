{
  "meta": {
    "key": "de.physio.professional_outpatient.full.v8",
    "name": "Physiotherapy (DE) Manual Pain Decision (TASK): Rx → Intake → Consent → Assessment → Pain Decision → Plan/Refer → Session loop → Outcome → Pain Decision → Report → Billing → Close",
    "version": 18,
    "country": "DE",
    "locale": "en-DE"
  },
  "nodes": [
    { "id": "start", "type": "START", "name": null, "actorRole": null, "contextKey": null, "form": null },

    {
      "id": "t_prescription_check",
      "type": "TASK",
      "name": "Prescription check (Heilmittel)",
      "actorRole": "RECEPTION",
      "contextKey": "prescription",
      "form": {
        "title": "Prescription / Heilmittel check",
        "fields": [
          { "key": "prescriptionType", "label": "Therapy type (Heilmittel)", "type": "select", "options": ["KG", "MT", "MLD", "KGG", "Other"], "required": true },
          { "key": "sessionsPrescribed", "label": "Prescribed sessions", "type": "number", "min": 0, "max": 60, "required": true },
          { "key": "valid", "label": "Prescription valid?", "type": "boolean", "required": true },
          { "key": "notes", "label": "Notes", "type": "text", "required": false }
        ]
      }
    },

    {
      "id": "t_intake",
      "type": "TASK",
      "name": "First consultation / intake",
      "actorRole": "PHYSIO",
      "contextKey": "intake",
      "form": {
        "title": "First consultation / intake",
        "fields": [
          { "key": "mainComplaint", "label": "Main complaint", "type": "text", "required": true },
          { "key": "baselinePain", "label": "Pain baseline (0–10)", "type": "number", "min": 0, "max": 10, "required": true },
          { "key": "goals", "label": "Therapy goals", "type": "text", "required": true },
          { "key": "notes", "label": "Notes", "type": "text", "required": false }
        ]
      }
    },

    {
      "id": "t_consent",
      "type": "TASK",
      "name": "Consent & GDPR documentation",
      "actorRole": "PHYSIO",
      "contextKey": "consent",
      "form": {
        "title": "Consent / GDPR",
        "fields": [
          { "key": "gdprConsent", "label": "Consent given", "type": "boolean", "required": true },
          { "key": "signatureName", "label": "Signature (name)", "type": "text", "required": true }
        ]
      }
    },

    {
      "id": "t_assessment",
      "type": "TASK",
      "name": "Assessment / examination",
      "actorRole": "PHYSIO",
      "contextKey": "assessment",
      "form": {
        "title": "Assessment / examination",
        "fields": [
          { "key": "painScore", "label": "Pain (0–10)", "type": "number", "min": 0, "max": 10, "required": true },
          { "key": "contraindications", "label": "Contraindications present?", "type": "boolean", "required": true },
          { "key": "notes", "label": "Clinical notes", "type": "text", "required": false }
        ]
      }
    },

    {
      "id": "t_pain_first_consult",
      "type": "TASK",
      "name": "Pain decision (after assessment)",
      "actorRole": "PHYSIO",
      "contextKey": "painFirst",
      "form": {
        "title": "Pain decision",
        "fields": [
          {
            "key": "painLevel",
            "label": "Select pain level",
            "type": "select",
            "options": ["LOW", "HIGH"],
            "required": true
          },
          {
            "key": "notes",
            "label": "Notes (optional)",
            "type": "text",
            "required": false
          }
        ]
      }
    },

    {
      "id": "t_refer_doctor_early",
      "type": "TASK",
      "name": "Refer back to doctor (early stop)",
      "actorRole": "PHYSIO",
      "contextKey": "doctorReferralEarly",
      "form": {
        "title": "Refer back to doctor (early stop)",
        "fields": [
          { "key": "reason", "label": "Reason", "type": "text", "required": true },
          { "key": "urgent", "label": "Urgent?", "type": "boolean", "required": true },
          { "key": "notes", "label": "Notes", "type": "text", "required": false }
        ]
      }
    },

    {
      "id": "t_plan",
      "type": "TASK",
      "name": "Treatment plan",
      "actorRole": "PHYSIO",
      "contextKey": "plan",
      "form": {
        "title": "Treatment plan",
        "fields": [
          { "key": "therapyType", "label": "Planned therapy type", "type": "select", "options": ["KG", "MT", "MLD", "KGG", "Other"], "required": true },
          { "key": "plannedSessions", "label": "Planned sessions", "type": "number", "min": 1, "max": 60, "required": true },
          { "key": "planNotes", "label": "Plan notes", "type": "text", "required": false }
        ]
      }
    },

    {
      "id": "t_session",
      "type": "TASK",
      "name": "Treatment session",
      "actorRole": "PHYSIO",
      "contextKey": "lastSession",
      "form": {
        "title": "Treatment session",
        "fields": [
          { "key": "sessionNumber", "label": "Session number", "type": "number", "min": 1, "max": 60, "required": true },
          { "key": "painBefore", "label": "Pain before (0–10)", "type": "number", "min": 0, "max": 10, "required": true },
          { "key": "painAfter", "label": "Pain after (0–10)", "type": "number", "min": 0, "max": 10, "required": true },
          { "key": "notes", "label": "Notes", "type": "text", "required": false }
        ]
      }
    },

    { "id": "x_more_sessions", "type": "XOR", "name": "More sessions?", "actorRole": null, "contextKey": null, "form": null },

    {
      "id": "t_outcome",
      "type": "TASK",
      "name": "Outcome / discharge",
      "actorRole": "PHYSIO",
      "contextKey": "outcome",
      "form": {
        "title": "Outcome / discharge",
        "fields": [
          { "key": "result", "label": "Outcome result", "type": "select", "options": ["better", "same", "worse"], "required": true },
          { "key": "painAtDischarge", "label": "Pain at discharge (0–10)", "type": "number", "min": 0, "max": 10, "required": true },
          { "key": "summary", "label": "Summary", "type": "text", "required": true }
        ]
      }
    },

    {
      "id": "t_pain_outcome",
      "type": "TASK",
      "name": "Pain decision (after outcome)",
      "actorRole": "PHYSIO",
      "contextKey": "painOutcome",
      "form": {
        "title": "Pain decision (discharge)",
        "fields": [
          {
            "key": "painLevel",
            "label": "Select pain level",
            "type": "select",
            "options": ["LOW", "HIGH"],
            "required": true
          },
          {
            "key": "notes",
            "label": "Notes (optional)",
            "type": "text",
            "required": false
          }
        ]
      }
    },

    {
      "id": "t_refer_doctor_outcome",
      "type": "TASK",
      "name": "Refer back to doctor (after outcome)",
      "actorRole": "PHYSIO",
      "contextKey": "doctorReferralOutcome",
      "form": {
        "title": "Refer back to doctor (after outcome)",
        "fields": [
          { "key": "reason", "label": "Reason", "type": "text", "required": true },
          { "key": "urgent", "label": "Urgent?", "type": "boolean", "required": true },
          { "key": "notes", "label": "Notes", "type": "text", "required": false }
        ]
      }
    },

    {
      "id": "t_report",
      "type": "TASK",
      "name": "Report (optional)",
      "actorRole": "PHYSIO",
      "contextKey": "report",
      "form": {
        "title": "Report",
        "fields": [
          { "key": "reportText", "label": "Report text", "type": "text", "required": false }
        ]
      }
    },

    {
      "id": "t_billing",
      "type": "TASK",
      "name": "Billing",
      "actorRole": "RECEPTION",
      "contextKey": "billing",
      "form": {
        "title": "Billing",
        "fields": [
          { "key": "billed", "label": "Billed?", "type": "boolean", "required": true },
          { "key": "notes", "label": "Notes", "type": "text", "required": false }
        ]
      }
    },

    {
      "id": "t_close_case",
      "type": "TASK",
      "name": "Close case",
      "actorRole": "RECEPTION",
      "contextKey": "closeCase",
      "form": {
        "title": "Case closure",
        "fields": [
          { "key": "closed", "label": "Case closed?", "type": "boolean", "required": true },
          { "key": "archiveNotes", "label": "Archive note", "type": "text", "required": false }
        ]
      }
    },

    { "id": "end", "type": "END", "name": null, "actorRole": null, "contextKey": null, "form": null }
  ],

  "edges": [
    { "from": "start", "to": "t_prescription_check", "condition": null },
    { "from": "t_prescription_check", "to": "t_intake", "condition": null },
    { "from": "t_intake", "to": "t_consent", "condition": null },
    { "from": "t_consent", "to": "t_assessment", "condition": null },

    { "from": "t_assessment", "to": "t_pain_first_consult", "condition": null },

    { "from": "t_pain_first_consult", "to": "t_refer_doctor_early", "condition": "ctx.painFirst.painLevel == \"HIGH\"" },
    { "from": "t_pain_first_consult", "to": "t_plan", "condition": "ctx.painFirst.painLevel == \"LOW\"" },
    { "from": "t_pain_first_consult", "to": "t_plan", "condition": "true" },

    { "from": "t_refer_doctor_early", "to": "t_close_case", "condition": null },

    { "from": "t_plan", "to": "t_session", "condition": null },
    { "from": "t_session", "to": "x_more_sessions", "condition": null },
    { "from": "x_more_sessions", "to": "t_session", "condition": "ctx.lastSession.sessionNumber < ctx.plan.plannedSessions" },
    { "from": "x_more_sessions", "to": "t_outcome", "condition": "true" },

    { "from": "t_outcome", "to": "t_pain_outcome", "condition": null },

    { "from": "t_pain_outcome", "to": "t_refer_doctor_outcome", "condition": "ctx.painOutcome.painLevel == \"HIGH\"" },
    { "from": "t_pain_outcome", "to": "t_report", "condition": "ctx.painOutcome.painLevel == \"LOW\"" },
    { "from": "t_pain_outcome", "to": "t_report", "condition": "true" },

    { "from": "t_refer_doctor_outcome", "to": "t_report", "condition": null },

    { "from": "t_report", "to": "t_billing", "condition": null },
    { "from": "t_billing", "to": "t_close_case", "condition": null },
    { "from": "t_close_case", "to": "end", "condition": null }
  ]
}